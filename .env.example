# XRPL OnTheTrack Terminal Environment Variables
# Copy this file to .env.local for local development.
# Add the same variables in Vercel Project Settings → Environment Variables.

# OTT normal account authentication (public browser configuration)
# Use the Supabase project URL and publishable key. Never use a service-role key in Vite variables.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallback supported by the client when a publishable key is not yet available:
VITE_SUPABASE_ANON_KEY=

# Social login feature flags
# Keep a provider false or unset until it is fully configured and tested in Supabase.
# The app hides providers that are not explicitly enabled.
VITE_AUTH_GOOGLE_ENABLED=false
VITE_AUTH_APPLE_ENABLED=false
VITE_AUTH_MICROSOFT_ENABLED=false
VITE_AUTH_GITHUB_ENABLED=false

# Trusted Supabase server configuration
# SUPABASE_SERVICE_ROLE_KEY is secret and must NEVER use the VITE_ prefix.
# It is used only by server functions after verifying the user's access token.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Required for AI Academy assessment
GEMINI_API_KEY=
# Optional model override
GEMINI_MODEL=gemini-2.5-flash

# Required for Xaman payload creation
# Server only. Never add VITE_ to either value.
XAMAN_API_KEY=
XAMAN_API_SECRET=

# XRPL endpoint used to validate certificate mint, offer and acceptance transactions.
# This endpoint MUST match OTT_CERTIFICATE_XRPL_NETWORK.
# Mainnet example: https://s1.ripple.com:51234/
# Testnet example: https://s.altnet.rippletest.net:51234/
XRPL_RPC_URL=https://s1.ripple.com:51234/

# Public canonical application URL used inside NFT metadata and Xaman return URLs.
OTT_PUBLIC_APP_URL=https://ott-terminal-mvp.vercel.app

# Foundation Certificate issuer controls
# No issuer seed/private key is stored. The configured issuer signs in Xaman.
OTT_CERTIFICATE_ISSUER_WALLET=
# Must be explicitly MAINNET or TESTNET before issuer payloads can be created.
OTT_CERTIFICATE_XRPL_NETWORK=
# Shared collection taxon. Defaults in code to SourceTag 2606170002 when unset.
OTT_CERTIFICATE_NFT_TAXON=2606170002
# Allowed bitmask: burnable=1, only-XRP=2, transferable=8, mutable-URI=16.
# Default 0 creates a fixed-URI certificate that cannot be transferred between third parties;
# the initial issuer-to-learner transfer is still supported by XRPL.
OTT_CERTIFICATE_NFT_FLAGS=0

# Founder accounts allowed to operate /?founder=1&issuer=1.
# Comma-separated. Configure at least one email or Supabase user UUID.
OTT_MINT_ADMIN_EMAILS=
OTT_MINT_ADMIN_USER_IDS=

# Destination wallet for Partner Proof Stamps
# Must be a valid XRPL r-address.
OTT_PROOF_DESTINATION_WALLET=

# Destination wallet for Truth Desk payments
# Must be a valid XRPL r-address.
OTT_TRUTH_DESK_WALLET=

# Destination wallet for Access Gate payments
# Must be a valid XRPL r-address.
OTT_ACCESS_WALLET=

# Project proof identity
# Do not change this in production.
MAKE_WAVES_SOURCE_TAG=2606170002
